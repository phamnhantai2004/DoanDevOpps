# ==========================================
# EventHub - Git Ignore Configuration
# ==========================================

# Dependencies (Root, Backend, Frontend)
node_modules/
**/node_modules/

# Production build outputs
dist/
**/dist/
build/
**/build/

# Local database files (SQLite)
# Since the backend uses SQLite (sql.js) and writes events.db locally,
# we must ignore the generated database files to avoid checking them into Git.
*.db
*.db-journal
*.sqlite
*.sqlite3
backend/events.db
backend/events.db-journal

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# IDEs & Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.pyc
venv/
.venv/

# AI Agent skills
.agents/
**/ .agents/
skills-lock.json
**/skills-lock.json
